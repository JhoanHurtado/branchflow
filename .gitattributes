###############################################################################
# BranchFlow Git Attributes
#
# This file defines how Git should treat certain files in the repository.
# It ensures consistent line endings, better diffs, and proper handling
# of binary files across different operating systems.
###############################################################################

# ---------------------------------------------------------------------------
# Default behavior
# ---------------------------------------------------------------------------

# Auto-detect text files and normalize to LF in the repository
* text=auto eol=lf


# ---------------------------------------------------------------------------
# Rust source files
# ---------------------------------------------------------------------------

*.rs text diff=rust
*.toml text
*.md text
*.yml text
*.yaml text


# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------

*.sh text eol=lf


# ---------------------------------------------------------------------------
# Windows scripts
# ---------------------------------------------------------------------------

*.bat text eol=crlf
*.ps1 text eol=crlf


# ---------------------------------------------------------------------------
# GitHub / CI configuration
# ---------------------------------------------------------------------------

.github/** text


# ---------------------------------------------------------------------------
# Binary files (no diff / no merge)
# ---------------------------------------------------------------------------

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary


# ---------------------------------------------------------------------------
# Lockfiles
# ---------------------------------------------------------------------------

Cargo.lock text


# ---------------------------------------------------------------------------
# Generated build artifacts (safety)
# ---------------------------------------------------------------------------

target/** -text
